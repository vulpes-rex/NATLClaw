{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://natlclaw.local/schemas/surface-event-v1.schema.json",
  "title": "surface-event-v1",
  "type": "object",
  "required": [
    "spec_version",
    "event_id",
    "event_type",
    "ts",
    "source",
    "session",
    "payload"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": [
        "adapter",
        "channel_type"
      ],
      "properties": {
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "channel_type": {
          "type": "string",
          "minLength": 1
        },
        "channel_instance": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "session": {
      "type": "object",
      "required": [
        "session_id"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "user_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "group_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "routing": {
      "type": "object",
      "properties": {
        "persona_hint": {
          "type": [
            "string",
            "null"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "normal",
            "high",
            "urgent"
          ]
        },
        "requires_reply": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "properties": {
        "trace_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
