# Provider (pick one)
PROVIDER=copilot

# GitHub Copilot (default)
# Authenticate with:  gh auth login
# Or set a PAT:       GITHUB_PAT=ghp_...
# PAT needs 'copilot' scope — https://github.com/settings/tokens
GITHUB_COPILOT_MODEL=claude-sonnet-4-6
# GITHUB_PAT=

# Azure Foundry (alternative)
# PROVIDER=foundry
# AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.api.azureml.ms/...
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# Azure OpenAI (alternative — same settings as CodeIntel)
# PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1-kvw
# AZURE_OPENAI_API_VERSION=2024-06-01
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small-kvw
# AZURE_OPENAI_EMBEDDING_API_VERSION=2023-05-15

# OpenAI (alternative)
# PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Ollama (alternative)
# PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# API Authentication (optional — if set, all API endpoints require Bearer token)
# NATL_API_KEY=your-secret-key-here

# Scheduler
HEARTBEAT_INTERVAL_SEC=120

# State
STATE_FILE=data/agent_state.json
MAX_HISTORY=100

# Agent
AGENT_NAME=NATLClaw
# PERSONA=default
AGENT_INSTRUCTIONS=You are a helpful assistant that performs periodic tasks, learns from past interactions, and maintains persistent memory.
